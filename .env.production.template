# Production Environment Configuration Template
# Copy to .env and fill in your actual values
# NEVER commit this file with real secrets to version control

# ===================================================================
# SECURITY & GENERAL SETTINGS
# ===================================================================
ENVIRONMENT=production
SECRET_KEY=your-super-secret-key-here-min-32-characters-required
DEBUG=false
LOG_LEVEL=INFO

# ===================================================================
# DOMAIN & URLS
# ===================================================================
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
API_URL=https://yourdomain.com/api
FRONTEND_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===================================================================
# DATABASE (PostgreSQL)
# ===================================================================
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_SECURE_PASSWORD@postgres:5432/sports_predictions
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD
POSTGRES_DB=sports_predictions

# Optional: Database connection pooling
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_ECHO=false

# ===================================================================
# REDIS (Caching & Rate Limiting)
# ===================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_IF_NEEDED

# ===================================================================
# AUTHENTICATION & JWT
# ===================================================================
JWT_EXPIRATION_HOURS=1
JWT_ALGORITHM=HS256
JWT_REFRESH_EXPIRATION_DAYS=7

# ===================================================================
# RATE LIMITING
# ===================================================================
# Requests per minute (adjust based on tier)
RATE_LIMIT_ANONYMOUS=30
RATE_LIMIT_AUTHENTICATED=100
RATE_LIMIT_PRO=300
RATE_LIMIT_PRO_PLUS=600
RATE_LIMIT_ELITE=1200

# ===================================================================
# EMAIL / SENDGRID (for notifications, password reset, etc.)
# ===================================================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_SENDER=noreply@yourdomain.com
SENDGRID_SENDER_NAME=SignalEdge AI

# ===================================================================
# PAYMENT / STRIPE
# ===================================================================
STRIPE_API_VERSION=2023-10-16
STRIPE_PUBLIC_KEY=pk_live_xxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Pricing (in cents)
STRIPE_PRICE_PRO_MONTHLY=999      # $9.99/month
STRIPE_PRICE_PRO_PLUS_MONTHLY=2999
STRIPE_PRICE_ELITE_MONTHLY=9999

# ===================================================================
# SPORTS DATA PROVIDERS
# ===================================================================
# The Odds API (required for live data)
ODDS_API_KEY=your-odds-api-key
ODDS_API_TIMEOUT=30

# ESPN API (public, no key needed)
ESPN_API_TIMEOUT=30

# ===================================================================
# ML MODEL SETTINGS
# ===================================================================
# Model paths
ML_MODELS_DIR=/app/ml-models/trained

# Training schedule (cron format)
ML_TRAINING_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC

# ===================================================================
# LOGGING & MONITORING
# ===================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# CloudWatch, DataDog, or similar
MONITORING_ENABLED=true

# ===================================================================
# SECURITY HEADERS (nginx handles most, but document here)
# ===================================================================
# HSTS: Force HTTPS for 1 year
# CSP: Restrict content sources
# X-Frame-Options: DENY
# X-Content-Type-Options: nosniff

# ===================================================================
# SSL/HTTPS - Let's Encrypt (Handled by docker-compose)
# ===================================================================
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# ===================================================================
# OPTIONAL: ADVANCED SETTINGS
# ===================================================================

# Session settings
SESSION_TIMEOUT_MINUTES=60
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# Cache settings
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# API timeouts
API_TIMEOUT_SECONDS=30
API_CONNECT_TIMEOUT_SECONDS=10

# Feature flags
ENABLE_ANALYTICS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SLACK_ALERTS=false
SLACK_WEBHOOK_URL=

# Backup & Maintenance
DB_BACKUP_ENABLED=true
DB_BACKUP_SCHEDULE=0 3 * * 0     # Weekly Sunday at 3 AM UTC
DB_BACKUP_RETENTION_DAYS=30

# ===================================================================
# NOTES FOR PRODUCTION
# ===================================================================
# 1. Generate a strong SECRET_KEY:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 2. Set secure database password (min 20 characters):
#    Use mix of uppercase, lowercase, numbers, symbols
#
# 3. Get Stripe API keys from:
#    https://dashboard.stripe.com/apikeys
#
# 4. Get SendGrid credentials from:
#    https://app.sendgrid.com/
#
# 5. Get Odds API key from:
#    https://the-odds-api.com/
#
# 6. Update domain references:
#    - Replace yourdomain.com with your actual domain
#    - Ensure DNS records point to server
#    - Verify Let's Encrypt certificates before launch
#
# 7. Security checklist before launch:
#    - [ ] All secrets are strong (32+ chars for SECRET_KEY)
#    - [ ] DATABASE_URL uses secure password
#    - [ ] STRIPE keys are LIVE (not test) keys
#    - [ ] Email notifications working
#    - [ ] Rate limiting configured appropriately
#    - [ ] HTTPS certificate valid
#    - [ ] Backups configured and tested
#    - [ ] Monitoring/alerts configured
#    - [ ] This file (.env) is in .gitignore
#
# ===================================================================
