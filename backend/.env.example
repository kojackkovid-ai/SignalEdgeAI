# ==========================================
# Sports Prediction Platform - Environment Configuration
# ==========================================

# Environment (development, staging, production)
ENVIRONMENT=development

# ==========================================
# Security (REQUIRED)
# ==========================================

# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-super-secret-key-here-minimum-32-characters-long

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# Database (PostgreSQL recommended for production)
# ==========================================

DB_USER=postgres
DB_PASS=your-db-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sports_predictions

# SQLite fallback is used automatically if PostgreSQL credentials are incomplete
# (development only - PostgreSQL required for production)

# ==========================================
# External APIs (REQUIRED for full functionality)
# ==========================================

# Odds API - Get your key at https://the-odds-api.com/
ODDS_API_KEY=your-odds-api-key-here

# ESPN API (no key required - public API)

# ==========================================
# Payment Processing (Stripe)
# ==========================================

STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ==========================================
# AI/LLM Configuration (OpenRouter)
# ==========================================

# Get your OpenRouter API key at https://openrouter.ai/
OPENAI_API_KEY=sk-or-v1-your-openrouter-api-key-here
LLM_MODEL=openai/gpt-4-turbo
LLM_PROVIDER=openrouter

# ==========================================
# Redis (Caching & Background Tasks)
# ==========================================

REDIS_URL=redis://localhost:6379

# ==========================================
# CORS & Security
# ==========================================

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,api.yourdomain.com

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# Enable HTTPS redirect (set to true in production)
ENABLE_HTTPS_REDIRECT=false

# ==========================================
# ML Model Configuration
# ==========================================

MODEL_UPDATE_INTERVAL=3600
RETRAIN_DAYS=7
MIN_TRAINING_SAMPLES=1000

# ==========================================
# Monitoring (Optional)
# ==========================================

# Sentry DSN for error tracking
SENTRY_DSN=

# ==========================================
# Development Settings
# ==========================================

# Enable debug logging
DEBUG=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
