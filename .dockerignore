# Ignore everything by default
**

# Explicitly include only what we need
!Dockerfile.fly
!.dockerignore
!backend/
!backend/app/
!backend/requirements.txt
!frontend/
!frontend/dist/
!frontend/dist/**

# Exclude everything we don't want
backend/.venv
backend/venv
backend/.venv/**
backend/venv/**
backend/__pycache__/**
backend/.pytest_cache/**
backend/.git/**
backend/ml-models
backend/ml-models/**
backend/models
backend/models/**
backend/.cache
backend/.cache/**
backend/**/*.db
backend/**/*.log
backend/**/*.pyc
backend/.env
backend/.env.local
!sports_predictions.db
!backend/sports_predictions.db

# Ignore common junk
.git
.gitignore
*.md
*.txt
*.log
.DS_Store
.env.example
.vscode
.idea
*.swp
*.swo
*~
